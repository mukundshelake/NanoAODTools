# NanoAODTools — Machine-Specific Configuration Template
#
# Copy this file to .env and fill in paths for your machine:
#   cp .env.template .env
#   vim .env
#
# DO NOT commit .env to git (it is already in .gitignore).
# Each machine has its own .env.
#
# Two real examples are provided at the bottom.
# See also .env.lxplus.example for a ready-made lxplus template.

# ============================================================
# Storage roots
# ============================================================

# Root directory that contains the raw (nfs_skimmed) NanoAOD
# tree files produced by CRAB.
# On TIFR  : /nfs/home/common/RUN2_UL/Tree_crab
# On lxplus: /eos/user/<initial>/<username>/RUN2_UL/Tree_crab
INPUT_STORAGE=/path/to/raw/nanoaod

# Root directory where all processed stage outputs are written
# (selection, reco, observables, BDTvariables, BDTScore).
# On TIFR  : /mnt/disk1/skimmed_Run2
# On lxplus: /eos/user/<initial>/<username>/skimmed_Run2
OUTPUT_STORAGE=/path/to/processed/output

# ============================================================
# Telegram notifications (optional)
# ============================================================
# Leave empty to disable
BOT_TOKEN=
CHAT_ID=

# ============================================================
# CMSSW (lxplus only, leave empty otherwise)
# ============================================================
CMSSW_BASE=

# ============================================================
# Example — TIFR machine (ehep154)
# ============================================================
# INPUT_STORAGE=/nfs/home/common/RUN2_UL/Tree_crab
# OUTPUT_STORAGE=/mnt/disk1/skimmed_Run2

# ============================================================
# Example — lxplus / EOS
# ============================================================
# INPUT_STORAGE=/eos/user/m/mshelake/RUN2_UL/Tree_crab
# OUTPUT_STORAGE=/eos/user/m/mshelake/skimmed_Run2
# CMSSW_BASE=/afs/cern.ch/work/m/mshelake/CMSSW_13_3_0
# WORK_DIR=/home/mukund/analysis
# CMSSW_BASE=

# LOCAL MACHINE (macOS)
# DATA_PATH=/Volumes/CMS_Data/nanoaod
# MC_PATH=/Volumes/CMS_Data/mc
# OUTPUT_PATH=/Volumes/CMS_Analysis/output
# EOS_PATH=
# WORK_DIR=/Users/mukund/analysis
# CMSSW_BASE=

# LXPLUS (CERN cluster)
# DATA_PATH=/eos/cms/store/data
# MC_PATH=/eos/cms/store/mc
# OUTPUT_PATH=/afs/cern.ch/work/m/mukund/analysis_output
# EOS_PATH=/eos/cms/store
# WORK_DIR=/afs/cern.ch/work/m/mukund/analysis
# CMSSW_BASE=/afs/cern.ch/work/m/mukund/CMSSW_12_4_2
